{
  "name": "self-healing-test-automation-factory",
  "version": "0.1.0",
  "private": true,
  "description": "Portfolio demo for recorder-driven Playwright generation and self-healing automation.",
  "type": "module",
  "scripts": {
    "start": "node src/app/server.js",
    "record": "node src/recorder/record.js",
    "record:sample": "node src/recorder/record-sample.js",
    "contract:validate": "node src/contract/validate-action-log.js",
    "test:contract": "node tests/action-log-contract-adapter.unit.js",
    "test:runtime-classifier": "node tests/runtime-result-classifier.unit.js",
    "test:security:unit": "node tests/security-library.unit.js",
    "generate:test": "node src/agents/run-generation.js",
    "test:json": "node src/runtime/run-action-log-test.js",
    "test:json:headed": "node src/runtime/run-action-log-test.js --headed",
    "test:e2e": "playwright test",
    "test:security": "node scripts/run-security-playwright.mjs",
    "test:security:headers": "node scripts/run-security-playwright.mjs headers",
    "test:security:response": "node scripts/run-security-playwright.mjs --checks=headers,cookies,data-exposure",
    "test:security:tampering": "node scripts/run-security-playwright.mjs --checks=request-tampering",
    "test:security:object-access": "node scripts/run-security-playwright.mjs --checks=object-access",
    "demo:security": "node scripts/run-security-playwright.mjs --headed",
    "demo:security:headers": "node scripts/run-security-playwright.mjs headers --headed",
    "demo:security:tampering": "node scripts/run-security-playwright.mjs --checks=request-tampering --headed",
    "demo:security:object-access": "node scripts/run-security-playwright.mjs --checks=object-access --headed"
  },
  "dependencies": {
    "@playwright/test": "^1.54.0",
    "express": "^4.19.2"
  },
  "devDependencies": {}
}
